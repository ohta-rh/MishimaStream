<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="color-scheme" content="dark">
  <meta name="theme-color" content="#0a0a0a">
  <meta name="description" content="回転扉的三島由紀夫 — リアルタイム共同お絵描きキャンバス">
  <meta name="keywords" content="三島由紀夫, Yukio Mishima, Mishima Stream, canvas, realtime">
  <meta property="og:title" content="Mishima Stream">
  <meta property="og:description" content="回転扉的三島由紀夫 — みんなで描くリアルタイムキャンバス">
  <meta property="og:type" content="website">
  <title><%= title %> — 回転扉的三島由紀夫</title>
  <link rel="icon" type="image/gif" href="/images/misima5.gif">
  <link rel="preload" as="image" href="/images/misima5.gif">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <a class="skip-link" href="#canvas">キャンバスへスキップ</a>

  <header class="hud" role="banner">
    <div class="hud__brand">
      <img class="hud__mark" src="/images/misima5.gif" alt="三島由紀夫" width="48" height="48" decoding="async">
      <div class="hud__title">
        <h1>Mishima Stream</h1>
        <p>回転扉的三島由紀夫</p>
      </div>
    </div>

    <div class="hud__status" aria-live="polite">
      <span class="dot dot--offline" data-el="status-dot" aria-hidden="true"></span>
      <span data-el="status-label">接続中…</span>
      <span class="hud__sep" aria-hidden="true">·</span>
      <span><output data-el="presence">0</output> 人が参加中</span>
    </div>
  </header>

  <main>
    <canvas id="canvas" aria-label="共同お絵描きキャンバス" tabindex="0"></canvas>
  </main>

  <aside class="tools" role="toolbar" aria-label="描画ツール">
    <label class="tools__field">
      <span>色</span>
      <input type="color" data-el="color" value="#ffffff">
    </label>
    <label class="tools__field">
      <span>太さ</span>
      <input type="range" data-el="size" min="1" max="48" step="1" value="6">
      <output data-el="size-value">6</output>
    </label>
    <button type="button" class="tools__btn" data-el="clear" aria-label="キャンバスを消去">消去</button>
  </aside>

  <footer class="foot">
    <small>&copy; Mishima Stream · Made with realtime &lt;canvas&gt;</small>
  </footer>

  <script type="module" src="/javascripts/app/main.js"></script>
</body>
</html>
